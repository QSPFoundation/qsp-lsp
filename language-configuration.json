{
  "comments": {
    "lineComment": "!"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "<<", "close": ">>", "notIn": ["comment"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["'", "'"],
    ["\"", "\""],
    ["<<", ">>"]
  ],
  "colorizedBracketPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "(?i)^\\s*(if\\b.*:|act\\b.*:|loop\\b.*:|elseif\\b.*:|else\\b.*:?|\\{)\\s*(!.*)?$",
    "decreaseIndentPattern": "(?i)^\\s*(end|elseif|else|\\})\\b"
  },
  "onEnterRules": [
    {
      "beforeText": "(?i)^\\s*(if\\b.*:|act\\b.*:|loop\\b.*:)\\s*(!.*)?$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "(?i)^\\s*(elseif\\b.*:|else\\b.*:?)\\s*(!.*)?$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "\\{\\s*$",
      "afterText": "^\\s*\\}",
      "action": { "indent": "indentOutdent" }
    },
    {
      "beforeText": "\\{\\s*$",
      "action": { "indent": "indent" }
    }
  ],
  "folding": {
    "markers": {
      "start": "(?i)^\\s*(#|if\\b|act\\b|loop\\b|\\{)",
      "end": "(?i)^\\s*(--|end\\b|\\})"
    }
  },
  "wordPattern": "[$#%]?[^\\s\\d'\"()\\[\\]=!<>+\\-/*:,{}&][^\\s'\"()\\[\\]=!<>+\\-/*:,{}&]*"
}
