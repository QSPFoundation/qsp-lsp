{
  "comments": {
    "lineComment": "!"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "<<", "close": ">>", "notIn": ["comment"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["'", "'"],
    ["\"", "\""],
    ["<<", ">>"]
  ],
  "colorizedBracketPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "indentationRules": {
    "increaseIndentPattern": {
      "pattern": "^\\s*(if\\b.*:|act\\b.*:|loop\\b.*:|elseif\\b.*:|else\\b.*:?|\\{)\\s*(!.*)?$",
      "flags": "i"
    },
    "decreaseIndentPattern": {
      "pattern": "^\\s*(end|elseif|else|\\})\\b",
      "flags": "i"
    }
  },
  "onEnterRules": [
    {
      "beforeText": {
        "pattern": "^\\s*(if\\b.*:|act\\b.*:|loop\\b.*:)\\s*(!.*)?$",
        "flags": "i"
      },
      "action": { "indent": "indent" }
    },
    {
      "beforeText": {
        "pattern": "^\\s*(elseif\\b.*:|else\\b.*:?)\\s*(!.*)?$",
        "flags": "i"
      },
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "\\{\\s*$",
      "afterText": "^\\s*\\}",
      "action": { "indent": "indentOutdent" }
    },
    {
      "beforeText": "\\{\\s*$",
      "action": { "indent": "indent" }
    }
  ],
  "folding": {
    "markers": {
      "start": {
        "pattern": "^\\s*(#|if\\b|act\\b|loop\\b|\\{)",
        "flags": "i"
      },
      "end": {
        "pattern": "^\\s*(--|end\\b|\\})",
        "flags": "i"
      }
    }
  },
  "wordPattern": "[$#%]?[^\\s\\d'\"()\\[\\]=!<>+\\-/*:,{}&][^\\s'\"()\\[\\]=!<>+\\-/*:,{}&]*"
}
