{
  "grammars": [
    {
      "name": "qsp",
      "camelcase": "Qsp",
      "scope": "source.qsp",
      "path": ".",
      "file-types": [
        "qsps",
        "qsrc"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for QSP (Quest Soft Player)",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-qsp"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
